# Dropbox access token for scripts that use the Dropbox API
DROPBOX_ACCESS_TOKEN=

# MongoDB connection strings
# Development / default connection
MONGODB_URI=
# Production connection (optional) 
MONGODB_URI_PROD=

# Database name used by the application
MONGODB_DB_NAME=IAMOOT-DB

# Google SMTP credentials (required for sending email)
# - GOOGLE_SENDER_EMAIL: the Gmail address used as sender
# - GOOGLE_APP_PASSWORD: a Google App Password (requires 2FA)
GOOGLE_SENDER_EMAIL=
GOOGLE_APP_PASSWORD=

# Optional: server port
PORT=3000